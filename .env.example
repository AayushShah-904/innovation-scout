# .env.example — Copy this to .env and fill in your values
# DO NOT commit .env to git (it's already in .gitignore)

# ── Gemini API Key ─────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Database Connection ────────────────────────────────────────────────────────
# For PRODUCTION (Supabase):
#   Get from: Supabase → Project Settings → Database → Connection String (URI mode)
#   Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@host:port/dbname

# For LOCAL DEVELOPMENT (Docker Compose):
#   Leave DATABASE_URL blank and use individual vars below, OR set DATABASE_URL to:
#   postgresql://admin:12345@localhost:5432/innovation_db
DB_NAME=innovation_db
DB_USER=admin
DB_PASSWORD=12345
DB_HOST=localhost
DB_PORT=5432
